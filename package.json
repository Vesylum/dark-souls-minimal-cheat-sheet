{
  "name": "dark-souls-minimal-cheat-sheet",
  "version": "1.0.0",
  "description": "Dark Souls Minimal Cheat Sheet",
  "type": "module",
  "repository": "https://github.com/Vesylum/dark-souls-minimal-cheat-sheet",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "eslint": "^9.28.0",
    "jquery": "^3.7.1",
    "jsdom": "^26.1.0",
    "qunit": "^2.20.0",
    "serve": "^14.2.4",
    "@testing-library/dom": "^10.4.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "start": "npx serve",
    "test": "qunit tests",
    "lint": "eslint js/*.js tests/*.cjs && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test:ui": "qunit tests/uiLocalStorageSync.test.cjs"
  }

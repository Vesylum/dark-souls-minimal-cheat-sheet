{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "node16",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "js/**/*.js",
    "scripts/**/*.js",
    "tests/**/*.cjs"
  ],
  "exclude": [
    "node_modules",
    "js/bootstrap.min.js",
    "js/jquery-3.7.1.min.js"
  ]
}
